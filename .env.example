# ─── ShadeMap ────────────────────────────────────────────────────────────────
# Obtain a free API key at https://shademap.app/about
# Expo exposes EXPO_PUBLIC_* variables at build-time (they are safe to bundle).
EXPO_PUBLIC_SHADEMAP_API_KEY=your_shademap_api_key_here

# ─── Optional overrides ───────────────────────────────────────────────────────
# Force shadow rendering mode:  'api' (default) | 'client' (offline fallback)
# EXPO_PUBLIC_SHADOW_MODE=api
