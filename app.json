{
  "expo": {
    "name": "sunny-coffee",
    "slug": "sunny-coffee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": null,
    "scheme": "sunnycoffee",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ch.vinzenzwolf.sunnycoffee",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sunny Coffee uses your location to show nearby cafés and calculate sun exposure from where you are."
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sunny Coffee uses your location to show nearby cafés and calculate sun exposure from where you are."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
